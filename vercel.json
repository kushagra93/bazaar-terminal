{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["bom1"],
  "env": {
    "FINNHUB_API_KEY": "@finnhub-api-key"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "s-maxage=3, stale-while-revalidate=10" }
      ]
    }
  ]
}
